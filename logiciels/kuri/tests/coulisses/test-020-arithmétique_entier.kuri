principale :: fonc ()
{  
    test_addition_entier();
    test_soustraction_entier();
    test_multiplication_entier();
    test_division_entier();
    test_modulo_entier();
}

test_addition_entier :: fonc ()
{
    si test_addition_entier(z8) != 125 {
        exit(1);
    }
    si test_addition_entier(z16) != 125 {
        exit(1);
    }
    si test_addition_entier(z32) != 125 {
        exit(1);
    }
    si test_addition_entier(z64) != 125 {
        exit(1);
    }

    si test_addition_entier(n8) != 125 {
        exit(1);
    }
    si test_addition_entier(n16) != 125 {
        exit(1);
    }
    si test_addition_entier(n32) != 125 {
        exit(1);
    }
    si test_addition_entier(n64) != 125 {
        exit(1);
    }
}

test_addition_entier :: fonc ($T: type_de_données) -> T
{
    a : T = 100;
    b : T = 25;
    retourne a + b;
}

