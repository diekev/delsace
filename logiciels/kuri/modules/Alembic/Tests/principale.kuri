chemin_archive_courante: chaine;

imprime_métadonnées_archives :: fonc (chemin: chaine)
{
    chemins: [..]chaine;
    diffère déloge_tableau_et_ses_éléments(*chemins);

    donne_chemins_du_dossier_récursif(chemin, *chemins, ".abc");

    applications_et_descriptions: [..]Application_Et_Description;

    pour chemins {
        iarchive := abc_input_archive_create(it);
        saufsi iarchive {
            imprimeln("Impossible d'ouvrir l'archive '%'", it);
            continue;
        }
        diffère abc_input_archive_destroy(iarchive);

        metadata := abc_input_archive_get_metadata(iarchive);
        diffère abc_metadata_destroy(metadata);

        iterator := abc_metadata_get_iterator(metadata);

        application: chaine;
        description: chaine;

        boucle {
            clé: Abc_String;
            valeur: Abc_String;

            saufsi abc_metadata_iterator_next(iterator, *clé, *valeur) {
                arrête;
            }

            si vers_kuri(clé) == "_ai_Application" {
                application = copie_chaine(vers_kuri(valeur));
            }
            sinon si vers_kuri(clé) == "_ai_Description" {
                description = copie_chaine(vers_kuri(valeur));
            }
        }

        si application || description {
            données := tableau_ajoute_élément(*applications_et_descriptions);
            données.application = application;
            données.description = description;
        }
    }

    tri_rapide(applications_et_descriptions, tri_par_application);

    application_courante := "";
    pour applications_et_descriptions {
        si application_courante != it.application {
            imprimeln("%", it.application);
            application_courante = it.application;
        }
        imprimeln("    %", it.description);
    }
}

imprime_hiérarchie_archive :: fonc (chemin: chaine)
{
    chemin_archive_courante = chemin;
    archive_courante_fut_imprimée = faux;

    iarchive := abc_input_archive_create(chemin);
    saufsi iarchive {
        imprimeln("Impossible d'ouvrir l'archive '%'", chemin);
        retourne;
    }
    diffère abc_input_archive_destroy(iarchive);

    top := abc_input_archive_get_top(iarchive);
    saufsi abc_input_object_valid(top) {
        imprimeln("L'object top n'est pas valide");
        retourne;
    }

    metadata := abc_input_archive_get_metadata(iarchive);
    diffère abc_metadata_destroy(metadata);

    imprime_metadata(metadata);

    pour abc_input_object_get_num_children(top) {
        header := abc_input_object_get_child_header(top, it);
        traverse_hiérarchie(top, header);
    }
}

traverse_hiérarchie :: fonc (parent: Abc_Generic_Input_Object, header: *Abc_Object_Header)
{
    nom: Abc_String;
    abc_object_header_get_name(header, *nom);
    next_object: Abc_Generic_Input_Object;
    user_properties: *Abc_Input_Compound_Property;
    arb_geom_params: *Abc_Input_Compound_Property;
    
    si abc_object_header_matches_camera(header) {
        camera := abc_input_camera_get(parent, nom);
        user_properties = abc_input_camera_get_user_properties(camera);
        arb_geom_params = abc_input_camera_get_arb_geom_params(camera);
        next_object = camera;
    }
    sinon si abc_object_header_matches_curves(header) {
        curves := abc_input_curves_get(parent, nom);
        user_properties = abc_input_curves_get_user_properties(curves);
        arb_geom_params = abc_input_curves_get_arb_geom_params(curves);
        next_object = curves;
    }
    sinon si abc_object_header_matches_faceset(header) {
        /* Les FaceSet sont gérés via les PolyMesh et SubD. */
    }
    sinon si abc_object_header_matches_light(header) {
        light := abc_input_light_get(parent, nom);
        user_properties = abc_input_light_get_user_properties(light);
        arb_geom_params = abc_input_light_get_arb_geom_params(light);
        next_object = light;
    }
    sinon si abc_object_header_matches_material(header) {
        material := abc_input_material_get(parent, nom);
        user_properties = abc_input_material_get_user_properties(material);
        arb_geom_params = abc_input_material_get_arb_geom_params(material);
        next_object = material;
    }
    sinon si abc_object_header_matches_nupatch(header) {
        nupatch := abc_input_nupatch_get(parent, nom);
        user_properties = abc_input_nupatch_get_user_properties(nupatch);
        arb_geom_params = abc_input_nupatch_get_arb_geom_params(nupatch);
        next_object = nupatch;
    }
    sinon si abc_object_header_matches_points(header) {
        points := abc_input_points_get(parent, nom);
        user_properties = abc_input_points_get_user_properties(points);
        arb_geom_params = abc_input_points_get_arb_geom_params(points);
        next_object = points;
    }
    sinon si abc_object_header_matches_polymesh(header) {
        polymesh := abc_input_polymesh_get(parent, nom);
        user_properties = abc_input_polymesh_get_user_properties(polymesh);
        arb_geom_params = abc_input_polymesh_get_arb_geom_params(polymesh);
        next_object = polymesh;
    }
    sinon si abc_object_header_matches_subd(header) {
        subd := abc_input_subd_get(parent, nom);
        user_properties = abc_input_subd_get_user_properties(subd);
        arb_geom_params = abc_input_subd_get_arb_geom_params(subd);
        next_object = subd;
    }
    sinon si abc_object_header_matches_xform(header) {
        xform := abc_input_xform_get(parent, nom);
        user_properties = abc_input_xform_get_user_properties(xform);
        arb_geom_params = abc_input_xform_get_arb_geom_params(xform);
        next_object = xform;
    }
    sinon {
        next_object = abc_input_object_get_child(parent, nom);

        si abc_input_object_is_instance_root(next_object.object) {
            abc_input_object_get_full_name(next_object, *nom);
            imprimeln("%", vers_kuri(nom));
        }
    }

    si abc_input_object_valid(next_object) {
        abc_input_object_get_full_name(next_object, *nom);
        imprimeln("%", vers_kuri(nom));

        metadata := abc_object_header_get_metadata(header);
        diffère abc_metadata_destroy(metadata);
        imprime_metadata(metadata);

        si user_properties {
            imprime_properties(user_properties, "User Properties");
        }
        si arb_geom_params {
            imprime_properties(arb_geom_params, "Arb Geom Params");
        }

        pour abc_input_object_get_num_children(next_object) {
            header = abc_input_object_get_child_header(next_object, it);
            traverse_hiérarchie(next_object, header);
        }
    }
}

imprime_metadata :: fonc (metadata: *Abc_MetaData)
{
    iterator := abc_metadata_get_iterator(metadata);
    boucle {
        clé: Abc_String;
        valeur: Abc_String;

        saufsi abc_metadata_iterator_next(iterator, *clé, *valeur) {
            arrête;
        }

        imprimeln("    % : %", vers_kuri(clé), vers_kuri(valeur));
    }
}

archive_courante_fut_imprimée: bool;

imprime_properties :: fonc (props: *Abc_Input_Compound_Property, nom: chaine)
{
    saufsi abc_input_compound_property_valid(props) {
       retourne;
    }

    imprimeln("    %", nom);
    num := abc_input_compound_property_get_num_properties(props);
    si num == 0 {
        imprimeln("        No properties");
        retourne;
    }

    // saufsi archive_courante_fut_imprimée {
    //     imprimeln("%", chemin_archive_courante);
    //     archive_courante_fut_imprimée = vrai;
    // }

    pour prop_index dans num {
        prop_header := abc_input_compound_property_get_property_header(props, prop_index);
        prop_header_name: Abc_String;
        abc_property_header_get_name(prop_header, *prop_header_name);

        prop_type := abc_property_header_get_property_type(prop_header);

        data_type: Abc_Data_Type;
        abc_property_header_get_data_type(prop_header, *data_type);

        imprimeln("        % (%, %, %)", vers_kuri(prop_header_name), prop_type, data_type.pod_type, data_type.extent);

        assert(data_type.extent <= 16);

        si prop_type == Abc_Property_Type.SCALAR {
            prop := abc_input_compound_property_get_scalar(props, prop_header_name);

            discr data_type.pod_type {
                BOOLEAN {
                    valeurs: [16]bool;
                    abc_input_scalar_property_bool_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                UINT8 {
                    valeurs: [16]n8;
                    abc_input_scalar_property_uchar_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                INT8 {
                    valeurs: [16]z8;
                    abc_input_scalar_property_char_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                UINT16 {
                    valeurs: [16]n16;
                    abc_input_scalar_property_uint16_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                INT16 {
                    valeurs: [16]z16;
                    abc_input_scalar_property_int16_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                UINT32 {
                    valeurs: [16]n32;
                    abc_input_scalar_property_uint32_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                INT32 {
                    valeurs: [16]z32;
                    abc_input_scalar_property_int32_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                UINT64 {
                    valeurs: [16]n64;
                    abc_input_scalar_property_uint64_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                INT64 {
                    valeurs: [16]z64;
                    abc_input_scalar_property_int64_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                FLOAT16 {}
                FLOAT32 {
                    valeurs: [16]r32;
                    abc_input_scalar_property_float_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                FLOAT64 {
                    valeurs: [16]r64;
                    abc_input_scalar_property_double_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", valeurs[it]);
                    }
                    imprime("\n");
                }
                STRING {
                    valeurs: [16]Abc_String;
                    abc_input_scalar_property_string_get(prop, *valeurs[0], Abc_Sample_Selector());
                    imprime("           ");
                    pour data_type.extent {
                        imprime(" %", vers_kuri(valeurs[it]));
                    }
                    imprime("\n");
                }
                WSTRING {}
                UNKNOWN {}
            }
        }

        metadata := abc_property_header_get_metadata(prop_header);
        diffère abc_metadata_destroy(metadata);

        imprime_metadata(metadata);
    }
}
