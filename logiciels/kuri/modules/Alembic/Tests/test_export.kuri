importe Alembic;
importe Math;

abc_output_archive_create :: fonc (chemin: chaine) -> *Abc_Output_Archive
{
    metadata: Abc_Output_Archive_Metadata;
    retourne abc_output_archive_create(chemin, *metadata);
}

abc_output_archive_create :: fonc (chemin: chaine, metadata: *Abc_Output_Archive_Metadata) -> *Abc_Output_Archive
{
    ctx_kuri := *ctx_kuri_pour_alembic;
    retourne abc_output_archive_create(ctx_kuri, vers_abc_string(chemin), metadata);
}

abc_output_archive_create_time_sampling :: fonc (archive: *Abc_Output_Archive, échantillons: []r64, temps_par_cycle: r64) -> Abc_Time_Sample_Index
{
    retourne abc_output_archive_create_time_sampling(archive, échantillons.pointeur, échantillons.taille comme n64, temps_par_cycle);
}

abc_output_xform_create :: fonc (parent: *Abc_Output_Xform, nom: chaine, ts: Abc_Time_Sample_Index) -> *Abc_Output_Xform
{
    retourne abc_output_xform_create(parent, vers_abc_string(nom), ts);
}

abc_output_points_create :: fonc (parent: *Abc_Output_Xform, nom: chaine, ts: Abc_Time_Sample_Index) -> *Abc_Output_Points
{
    retourne abc_output_points_create(parent, vers_abc_string(nom), ts);
}

abc_output_points_sample_positions_set :: fonc (sample: *Abc_Output_Points_Sample, positions: []Vec3)
{
    array_sample: Abc_P3f_Array_Sample = ---;
    array_sample.values = positions.pointeur comme *Abc_V3f;
    array_sample.num_values = positions.taille comme n64;
    abc_output_points_sample_positions_set(sample, array_sample);
}

abc_output_points_sample_ids_set :: fonc (sample: *Abc_Output_Points_Sample, ids: []n64)
{
    array_sample: Abc_UInt64_Array_Sample = ---;
    array_sample.values = ids.pointeur;
    array_sample.num_values = ids.taille comme n64;
    abc_output_points_sample_ids_set(sample, array_sample);
}

abc_output_curves_create :: fonc (parent: *Abc_Output_Xform, nom: chaine, time_sample_index: Abc_Time_Sample_Index) -> *Abc_Output_Curves
{
    retourne abc_output_curves_create(parent, vers_abc_string(nom), time_sample_index);
}

abc_output_curves_sample_positions_set :: fonc (sample: *Abc_Output_Curves_Sample, positions: []Vec3)
{
    array_sample: Abc_P3f_Array_Sample = ---;
    array_sample.values = positions.pointeur comme *Abc_V3f;
    array_sample.num_values = positions.taille comme n64;
    abc_output_curves_sample_positions_set(sample, array_sample);
}

abc_output_curves_sample_curves_num_vertices_set :: fonc (sample: *Abc_Output_Curves_Sample, num_vertices: []z32)
{
    array_sample: Abc_Int32_Array_Sample = ---;
    array_sample.values = num_vertices.pointeur;
    array_sample.num_values = num_vertices.taille comme n64;
    abc_output_curves_sample_curves_num_vertices_set(sample, array_sample);
}

abc_output_curves_sample_widths_set :: fonc (sample: *Abc_Output_Curves_Sample, values: []r32, scope: Abc_Geometry_Scope)
{
    geom_param: Abc_Output_Float_Geom_Param_Sample;
    geom_param.values = values.pointeur;
    geom_param.num_values = values.taille comme n64;
    geom_param.scope = scope;
    abc_output_curves_sample_widths_set(sample, geom_param);
}

/* ------------------------------------------------------------------------- */
/** \nom OCompoundProperty
 * \{ */

importe Fondation;

add_scalar_property :: fonc (props: *Abc_Output_Compound_Property, name: chaine, data_type: Abc_Data_Type, ts_index: Abc_Time_Sample_Index) -> *Abc_Output_Scalar_Property
{
    retourne abc_output_scalar_property_create(props, vers_abc_string(name), data_type, ts_index);
}

add_scalar_property :: fonc (props: *Abc_Output_Compound_Property, name: chaine, valeur: $T, ts_index: Abc_Time_Sample_Index)
{
    #si T == bool {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.BOOLEAN;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_bool_set(prop, valeur);
    }
    sinon si T == n8 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.UINT8;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_uchar_set(prop, valeur);
    }
    sinon si T == z8 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.INT8;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_char_set(prop, valeur);
    }
    sinon si T == n16 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.UINT16;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_uint16_set(prop, valeur);
    }
    sinon si T == z16 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.INT16;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_int16_set(prop, valeur);
    }
    sinon si T == n32 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.UINT32;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_uint32_set(prop, valeur);
    }
    sinon si T == z32 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.INT32;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_int32_set(prop, valeur);
    }
    sinon si T == n64 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.UINT64;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_uint64_set(prop, valeur);
    }
    sinon si T == z64 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.INT64;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_int64_set(prop, valeur);
    }
    // sinon si T == r16 {
    // FLOAT16;
    // }
    sinon si T == r32 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.FLOAT32;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_float_set(prop, valeur);
    }
    sinon si T == r64 {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.FLOAT64;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_double_set(prop, valeur);
    }
    sinon si T == chaine {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.STRING;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_string_set(prop, vers_abc_string(valeur));
    }
    sinon si T == Abc_String {
        data_type: Abc_Data_Type;
        data_type.extent = 1;
        data_type.pod_type = Abc_Plain_Old_Data_Type.STRING;
        prop := add_scalar_property(props, name, data_type, ts_index);
        abc_output_scalar_property_string_set(prop, valeur);
    }
    sinon {
        imprimeln("Type de données non-supporté");
    }
}

/** \} */

principale :: fonc ()
{
    crée_test_user_props_scalar("/tmp/scalar-props-in-user-props.abc", vrai);
    crée_test_user_props_scalar("/tmp/scalar-props-in-geom-params.abc", faux);
    // crée_test_rayons_courbes("/tmp/curve-with-width.abc", vrai);
    // crée_test_rayons_courbes("/tmp/curve-without-width.abc", faux);
    // crée_test_rayons_points("/tmp/point-with-width.abc", vrai);
    // crée_test_rayons_points("/tmp/point-without-width.abc", faux);
}

crée_test_user_props_scalar :: fonc (chemin: chaine, dans_user_props: bool)
{
    metadata: Abc_Output_Archive_Metadata;
    metadata.application_name = vers_abc_string("Jorjala");
    metadata.fps = 24.0;

    archive := abc_output_archive_create(chemin, *metadata);
    diffère abc_output_archive_destroy(archive);

    ts_défaut := abc_output_archive_default_time_sampling(archive);

    racine := abc_output_archive_root_object_get(archive);

    matrice_objet_point := crée_xform_neutre_pour_objet(archive, racine, "PointCloud", ts_défaut);

    objet_point := abc_output_points_create(matrice_objet_point, "PointCloudPoints", ts_défaut);
    point_sample := abc_output_points_sample_create(archive);
    diffère abc_output_points_sample_destroy(point_sample);

    position := Vec3(0.0, 0.0, 0.0);
    abc_output_points_sample_positions_set(point_sample, [position]);

    ids := n64.[0];
    abc_output_points_sample_ids_set(point_sample, ids);

    abc_output_points_sample_set(objet_point, point_sample);

    user_props := si dans_user_props {
        abc_output_points_user_properties_get(objet_point);
    }
    sinon {
        abc_output_points_arb_geom_params_get(objet_point);
    };

    add_scalar_property(user_props, "prop-bool", vrai, ts_défaut);
    add_scalar_property(user_props, "prop-int8", 123 comme z8, ts_défaut);
    add_scalar_property(user_props, "prop-int16", 123 comme z16, ts_défaut);
    add_scalar_property(user_props, "prop-int32", 123, ts_défaut);
    add_scalar_property(user_props, "prop-int64", 123 comme z64, ts_défaut);
    add_scalar_property(user_props, "prop-uint8", 123 comme n8, ts_défaut);
    add_scalar_property(user_props, "prop-uint16", 123 comme n16, ts_défaut);
    add_scalar_property(user_props, "prop-uint32", 123 comme n32, ts_défaut);
    add_scalar_property(user_props, "prop-uint64", 123 comme n64, ts_défaut);
    add_scalar_property(user_props, "prop-float32", 1.23, ts_défaut);
    add_scalar_property(user_props, "prop-float64", 1.23 comme r64, ts_défaut);
    add_scalar_property(user_props, "prop-string", "123", ts_défaut);
}

crée_test_rayons_courbes :: fonc (chemin: chaine, export_rayon: bool)
{
    metadata: Abc_Output_Archive_Metadata;
    metadata.application_name = vers_abc_string("Jorjala");
    metadata.fps = 24.0;

    archive := abc_output_archive_create(chemin, *metadata);
    diffère abc_output_archive_destroy(archive);

    ts_défaut := abc_output_archive_default_time_sampling(archive);

    racine := abc_output_archive_root_object_get(archive);

    matrice_curves := crée_xform_neutre_pour_objet(archive, racine, "Curves", ts_défaut);

    échantillons := [1.0 / metadata.fps];
    temps_par_cycle := 1.0 / metadata.fps;
    ts_animation := abc_output_archive_create_time_sampling(archive, échantillons, temps_par_cycle);

    curves := abc_output_curves_create(matrice_curves, "CurvesGeom", ts_animation);

    curves_sample := abc_output_curves_sample_create(archive);
    diffère abc_output_curves_sample_destroy(curves_sample);

    cx := 0.0;
    cy := 0.0;

    rx := 1.0;
    ry := 1.0;

    segs := 100;

    phi_delta := Constantes(r32).TAU / segs comme r32;

    phi := 0.0;

    pour segs {
        abc_output_curves_sample_reset(curves_sample);

        ca0 := cx + cosinus(phi) * rx;
        sa0 := cy + sinus(phi) * ry;

        phi += phi_delta;

        abc_output_curves_sample_type_set(curves_sample, Abc_Curve_Type.LINEAR);

        abc_output_curves_sample_basis_set(curves_sample, Abc_Basis_Type.NO_BASIS);

        positions := [Vec3(0.0, 0.0, 0.0), Vec3(ca0, 0.0, sa0)];
        abc_output_curves_sample_positions_set(curves_sample, positions);

        num_vertices := z32.[2];
        abc_output_curves_sample_curves_num_vertices_set(curves_sample, num_vertices);

        si export_rayon {
            width := 50 - abs((it + 1) - 50);
            widths := r32.[width comme r32 * 0.01, width comme r32 * 0.01];
            abc_output_curves_sample_widths_set(curves_sample, widths, Abc_Geometry_Scope.VERTEX);
        }

        abc_output_curves_sample_set(curves, curves_sample);
    }
}

crée_test_rayons_points :: fonc (chemin: chaine, export_rayon: bool)
{
    metadata: Abc_Output_Archive_Metadata;
    metadata.application_name = vers_abc_string("Jorjala");
    metadata.fps = 24.0;

    archive := abc_output_archive_create(chemin, *metadata);
    diffère abc_output_archive_destroy(archive);

    ts_défaut := abc_output_archive_default_time_sampling(archive);

    racine := abc_output_archive_root_object_get(archive);

    échantillons := [1.0 / metadata.fps];
    temps_par_cycle := 1.0 / metadata.fps;
    ts_animation := abc_output_archive_create_time_sampling(archive, échantillons, temps_par_cycle);

    matrice_objet_point := crée_xform_neutre_pour_objet(archive, racine, "PointCloud", ts_défaut);

    objet_point := abc_output_points_create(matrice_objet_point, "PointCloudPoints", ts_animation);
    point_sample := abc_output_points_sample_create(archive);
    diffère abc_output_points_sample_destroy(point_sample);

    cx := 0.0;
    cy := 0.0;

    rx := 1.0;
    ry := 1.0;

    segs := 100;

    phi_delta := Constantes(r32).TAU / segs comme r32;

    phi := 0.0;

    pour segs {
        abc_output_points_sample_reset(point_sample);

        ca0 := cx + cosinus(phi) * rx;
        sa0 := cy + sinus(phi) * ry;

        phi += phi_delta;

        position := Vec3(ca0, 0.0, sa0);
        abc_output_points_sample_positions_set(point_sample, [position]);

        ids := n64.[0];
        abc_output_points_sample_ids_set(point_sample, ids);

        si export_rayon {
            width := 50 - abs((it + 1) - 50);
            widths := r32.[width comme r32 * 0.01];

            geom_param: Abc_Output_Float_Geom_Param_Sample;
            geom_param.values = *widths[0];
            geom_param.num_values = 1;
            geom_param.scope = Abc_Geometry_Scope.VERTEX;

            abc_output_points_sample_widths_set(point_sample, geom_param);
        }

        abc_output_points_sample_set(objet_point, point_sample);
    }
}

crée_xform_neutre_pour_objet :: fonc (archive: *Abc_Output_Archive, parent: *Abc_Output_Xform, nom: chaine, ts: Abc_Time_Sample_Index) -> *Abc_Output_Xform
{
    résultat := abc_output_xform_create(parent, nom, ts);

    matrix_sample := abc_output_xform_sample_create(archive);
    diffère abc_output_xform_sample_destroy(matrix_sample);

    matrix: Abc_M44d;
    matrix.x[0][0] = 1.0;
    matrix.x[1][1] = 1.0;
    matrix.x[2][2] = 1.0;
    matrix.x[3][3] = 1.0;

    abc_output_xform_sample_set_matrix(matrix_sample, *matrix);

    abc_output_xform_sample_set(résultat, matrix_sample);

    retourne résultat;
}
