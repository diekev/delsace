rends_contexte_gl_actif :: fonc (fenêtre: Port_Fenêtre_Native)
{
    assert(fenêtre.système == SystèmeFenêtre.QT);
    assert(fenêtre.rappels_window != nul);
    assert(fenêtre.rappels_window.window != nul);
     _ := QT_OpenGL_Context_make_current(fenêtre.rappels_window.glctx, fenêtre.rappels_window.window);
}

