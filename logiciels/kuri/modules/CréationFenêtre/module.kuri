importe Chaine;
importe Fondation;
importe Math;
importe MIME;
importe OpenGL;
importe Périphériques;

SystèmeFenêtre :: énum {
    QT;
    NATIVE;
}

Genre_Fenêtre :: énum {
    NORMALE;
    MENU;
}

Options_Création_Fenêtre :: struct {
    position_x: z32 = -1;
    position_y: z32 = -1;
    largeur: z32;
    hauteur: z32;
    titre: chaine;
    maximisée: bool;
    indice_écran: z32;
    avec_barre_de_titre_et_bordures: bool;
    genre_fenêtre: Genre_Fenêtre;
}

crée_fenêtre :: fonc (largeur: z32, hauteur: z32, titre: chaine, maximisée := faux, index_écran := 0, avec_barre_de_titre_et_bordures := vrai, système := SystèmeFenêtre.QT, parent: *Port_Fenêtre_Native = nul) -> Port_Fenêtre_Native
{
    options: Options_Création_Fenêtre;
    options.largeur = largeur;
    options.hauteur = hauteur;
    options.maximisée = maximisée;
    options.titre = titre;
    options.indice_écran = index_écran;
    options.avec_barre_de_titre_et_bordures = avec_barre_de_titre_et_bordures;
    retourne crée_fenêtre(*options, système, parent);
}

crée_fenêtre :: fonc (options: *Options_Création_Fenêtre, système := SystèmeFenêtre.QT, parent: *Port_Fenêtre_Native = nul) -> Port_Fenêtre_Native
{
    si système == SystèmeFenêtre.NATIVE {
        retourne x11_crée_fenêtre(options);
    }

    retourne qt_crée_fenêtre(options, parent);
}

ajourne_évènements_fenêtre :: fonc (type_fenêtre: Port_Fenêtre_Native) -> []Évènement
{
    si type_fenêtre.système == SystèmeFenêtre.NATIVE {
        pour __évènements {
            déloge(*it.texte);

            pour données_mime dans it.mimes {
                déloge(*données_mime.type);
                déloge(*données_mime.données);
            }

            déloge(*it.mimes);
        }
        __évènements.taille = 0;
        x11_ajourne_évènements_fenêtre(type_fenêtre);
    }
    sinon {
        assert(type_fenêtre.système == SystèmeFenêtre.QT);
        __évènements.taille = 0;
        qt_ajourne_évènements_fenêtre(type_fenêtre);
    }

    retourne __évènements;
}

requiers_ajournement_fenêtre :: fonc (fenêtre: Port_Fenêtre_Native)
{
